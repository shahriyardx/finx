{
  "expo": {
    "name": "FinX",
    "slug": "finx",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "finx",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#163300",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 11,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECEIVE_SMS"
      ],
      "package": "com.shahriyardx.finx"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#163300",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock FinX."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FinX to access your photos for profile pictures and receipts.",
          "cameraPermission": "Allow FinX to use the camera to capture receipt photos.",
          "microphonePermission": false
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow FinX to access contacts to fill a person's phone number."
        }
      ],
      "expo-sharing",
      [
        "expo-notifications",
        {
          "color": "#163300"
        }
      ],
      [
        "react-native-android-widget",
        {
          "fonts": ["./assets/fonts/MaterialCommunityIcons.ttf"],
          "widgets": [
            {
              "name": "Balance",
              "label": "FinX Balance",
              "description": "Your total balance",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
